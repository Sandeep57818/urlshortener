# ============================================================
# PRODUCTION URL SHORTENER — Environment Variables
# ============================================================

# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
SHORT_DOMAIN=http://localhost:4000

# PostgreSQL
DATABASE_URL=postgresql://urluser:urlpass@localhost:5432/urlshortener
POSTGRES_USER=urluser
POSTGRES_PASSWORD=urlpass
POSTGRES_DB=urlshortener

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-min-64-chars
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456

# GeoIP (optional — free tier)
GEOIP_API=https://ipapi.co

# Prometheus
METRICS_TOKEN=metrics-secret-token
